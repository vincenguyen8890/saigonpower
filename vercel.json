{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/renewals",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/activity-reminders",
      "schedule": "0 8 * * 1-5"
    }
  ]
}
