# ============================================================
# SAIGON POWER - Environment Variables
# Copy this to .env.local and fill in values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PHONE=(832) 937-9999
NEXT_PUBLIC_EMAIL=info@saigonllc.com

# Google Places API (for Google Reviews)
# 1. Go to console.cloud.google.com → Enable "Places API"
# 2. Create API key → restrict to Places API
# 3. Find your Place ID at: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=AIza...your-key-here
GOOGLE_PLACE_ID=ChIJ...your-place-id-here
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJ...your-place-id-here

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email (optional - for notifications)
RESEND_API_KEY=re_xxxx
NOTIFICATION_EMAIL=admin@giadienre.com

# AI (future)
# OPENAI_API_KEY=sk-xxxx
